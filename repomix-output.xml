    allContainers.forEach(container => container.classList.add('hidden'));
    const targetId = tab.dataset.target;
    const targetContainer = document.querySelector(`#${targetId}-content`);

    if (targetContainer) {
        targetContainer.classList.remove('hidden');
    }

})
